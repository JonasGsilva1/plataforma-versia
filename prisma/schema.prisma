generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  fullName     String
  email        String        @unique
  passwordHash String
  photoUrl     String?
  createdAt    DateTime      @default(now())
  accounts     Account[]
  transactions Transaction[]
  consents     OpenFinanceConsent[]
}

model Account {
  id                         String   @id @default(cuid())
  userId                     String
  bankName                   String   @default("Deas Finance")
  availableBalance           Decimal  @default(0)
  debt                       Decimal  @default(0)
  limit                      Decimal  @default(0)
  creditScore                Int      @default(500)
  preApproved                Decimal  @default(0)
  loansTotal                 Decimal  @default(0)
  estimatedIncome            Decimal  @default(0)
  openFinancePartnerSnapshot Json?
  updatedAt                  DateTime @updatedAt
  user                       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  accountId String
  creditor  String
  type      String
  value     Decimal
  status    String
  date      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OpenFinanceConsent {
  id                 String    @id @default(cuid())
  userId             String
  sourceBank         String
  targetBank         String
  status             String    @default("active")
  sharedScore        Boolean   @default(true)
  sharedTransactions Boolean   @default(true)
  sharedBalance      Boolean   @default(true)
  requestedSalary    Decimal?
  partnerSnapshot    Json?
  createdAt          DateTime  @default(now())
  revokedAt          DateTime?
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AppState {
  id        String   @id
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
