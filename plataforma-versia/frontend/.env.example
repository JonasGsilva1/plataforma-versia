# Cópia de referência — use para criar o seu .env.local

# URL base para chamadas à API pelo browser (via proxy do Next)
NEXT_PUBLIC_API_URL=/api

# Backend Django (tenant) — usado pelo rewrite do Next.js (server-side)
# Em produção, troque pelo domínio real do tenant.
NEXT_PUBLIC_API_PROXY_URL=http://demo.localhost:8000
